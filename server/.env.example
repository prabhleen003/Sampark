PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
JWT_SECRET=replace_with_a_long_random_string
# 32+ char random string — used to AES-256 encrypt phone numbers at rest. NEVER leave unset.
PHONE_ENCRYPT_KEY=replace_with_32_char_random_string
# Set this in the Exotel dashboard as: POST /api/v1/webhooks/exotel?token=<value>
EXOTEL_WEBHOOK_SECRET=replace_with_a_long_random_string
